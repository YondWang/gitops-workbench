# Copy this file to /opt/gitops-workbench/.env on the server.
# Do not commit or share the real .env file.

# GitLab personal access token. It needs the api scope and Maintainer access
# for branch protection operations.
GITLAB_TOKEN=replace-with-a-gitlab-token

# Production login credentials for the GitOps Workbench UI.
GITOPS_ADMIN_PASSWORD=replace-with-a-strong-admin-password
GITOPS_USER_PASSWORD=replace-with-a-strong-user-password

# Generate with: openssl rand -base64 48
GITOPS_SESSION_SECRET=replace-with-a-long-random-secret

# Force containers on the same server to reach GitLab through the internal IP
# while still using the certificate hostname www.chancee-shanghai.cn.
GITLAB_HOST_IP=192.168.110.222

# Single-container HTTPS. These files are mounted read-only from the server's
# existing GitLab certificate directory and are not modified by this project.
GITOPS_TLS_CERT=/etc/gitlab/ssl/chancee-shanghai.cn-crt.pem
GITOPS_TLS_KEY=/etc/gitlab/ssl/chancee-shanghai.cn-key.pem

# Base image mirror. This avoids pulling directly from Docker Hub.
PYTHON_BASE_IMAGE=docker.m.daocloud.io/python:3.12-slim
