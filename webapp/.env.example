GITLAB_BASE_URL=https://www.chancee-shanghai.cn:9900
GITLAB_PROJECT=software_hmi_app/business
GITLAB_TOKEN=replace-with-a-gitlab-token
GITLAB_SSL_VERIFY=true

# For additional repositories, either reuse GITLAB_TOKEN or create another
# environment variable and set token_env to that name in the web UI.
# GITLAB_TOKEN_OTHER=replace-with-another-gitlab-token

# Optional server binding.
GITOPS_HOST=127.0.0.1
GITOPS_PORT=8765

# Default login passwords are admin/admin123 and user/user123.
# Override them before exposing the service beyond localhost.
GITOPS_ADMIN_PASSWORD=change-admin-password
GITOPS_USER_PASSWORD=change-user-password
GITOPS_SESSION_SECRET=replace-with-a-long-random-string

# Optional advanced user config. Passwords are hashed in memory if provided here.
# GITOPS_USERS_JSON={"admin":{"role":"admin","password":"change-me"},"user":{"role":"user","password":"change-me"}}

# Optional: when simos tag pipelines run on a cloud runner, read resident outputs from GitLab job artifacts.
SIMOS_CI_ARTIFACT_JOB_NAMES=resident,resident-package,package,build
SIMOS_CI_ARTIFACT_FILE=resident.tar.gz
SIMOS_CI_BUILD_INFO_FILE=build-info.json
